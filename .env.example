# ── Database ───────────────────────────────────────────────────────────────
PRISMRAG_DB_DSN=postgresql://prismrag:prismrag@localhost:5432/prismrag

# ── Gemini (Google AI) ─────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Auth ───────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_to_a_random_64_char_string

# ── Stripe ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs from your Stripe dashboard (Products → Prices)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── App ────────────────────────────────────────────────────────────────────
PRISMRAG_ENV=development   # development | production
PRISMRAG_PORT=8001

# ── Async processing (recommended) ─────────────────────────────────────────
PRISMRAG_USE_JOB_QUEUE=true

# ── Azure Communication Services Email (PrismRAG@insightits.com) ───────────
# See DOC/azure-email-aws-dns.md — domain DNS stays in AWS Route 53
AZURE_COMMUNICATION_CONNECTION_STRING=
PRISMRAG_EMAIL_FROM=PrismRAG@insightits.com
PRISMRAG_EMAIL_ENABLED=true

# ── CMEK (enterprise) ─────────────────────────────────────────────────────
PRISMRAG_CMEK_ENABLED=false
